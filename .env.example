# ---- AI APIs ----
GEMINI_API_KEY=your_gemini_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Optional: override Gemini model (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# ---- Auth ----
SKIP_AUTH=True

# ---- Snowflake ----
SNOWFLAKE_ACCOUNT=your_account_here
SNOWFLAKE_USER=your_user_here
SNOWFLAKE_PASSWORD=your_password_here
SNOWFLAKE_DATABASE=your_database_here
SNOWFLAKE_SCHEMA=your_schema_here
SNOWFLAKE_WAREHOUSE=your_warehouse_here

# ---- Django ----
DJANGO_SECRET_KEY=django-insecure-change-this-for-production-use-a-long-random-string
DJANGO_DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ---- Database (PostgreSQL) ----
# If using Docker: postgresql://postgres:postgres@localhost:5432/voicebridge
# If using SQLite for local dev: leave blank and settings.py will fall back to SQLite
DATABASE_URL=

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- CORS (comma-separated frontend origins) ----
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
